{
  "uid": "g4os-mcp",
  "title": "G4OS MCP Subprocesses",
  "description": "Subprocesses MCP stdio: count, RSS por subprocess, tool latency, zumbis",
  "tags": ["g4os", "mcp", "subprocess"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(g4os_mcp_subprocess_count, service)",
        "current": { "text": "g4os-desktop", "value": "g4os-desktop" },
        "multi": true,
        "includeAll": true
      },
      {
        "name": "env",
        "type": "custom",
        "query": "dev,staging,prod",
        "current": { "text": "dev", "value": "dev" },
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Subprocesses ativos",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "g4os_mcp_subprocess_count{service=~\"$service\"}",
          "legendFormat": "count"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Tool calls / min",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(rate(g4os_mcp_tool_call_total{service=~\"$service\"}[1m]) * 60)",
          "legendFormat": "calls/min"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Tool errors / min",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(rate(g4os_mcp_tool_call_errors_total{service=~\"$service\"}[1m]) * 60)",
          "legendFormat": "errors/min"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Zombie subprocesses",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "g4os_mcp_subprocess_count{service=~\"$service\"} - g4os_mcp_subprocess_active{service=~\"$service\"}",
          "legendFormat": "zombies"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Subprocess count over time",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "g4os_mcp_subprocess_count{service=~\"$service\"}",
          "legendFormat": "total"
        },
        {
          "expr": "g4os_mcp_subprocess_active{service=~\"$service\"}",
          "legendFormat": "active"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "RSS por subprocess (top 10)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "expr": "topk(10, g4os_mcp_subprocess_rss_bytes{service=~\"$service\"})",
          "legendFormat": "{{slug}}"
        }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Tool call duration p95 — por tool",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by(tool, le) (rate(g4os_mcp_tool_call_duration_seconds_bucket{service=~\"$service\"}[5m])))",
          "legendFormat": "{{tool}}"
        }
      ]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Tool error rate por slug",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [
        {
          "expr": "sum by(slug) (rate(g4os_mcp_tool_call_errors_total{service=~\"$service\"}[5m])) / sum by(slug) (rate(g4os_mcp_tool_call_total{service=~\"$service\"}[5m]))",
          "legendFormat": "{{slug}}"
        }
      ]
    }
  ]
}
