{
  "uid": "g4os-overview",
  "title": "G4OS Overview",
  "description": "Métricas do processo Electron desktop (prom-client via port 9464)",
  "tags": ["g4os", "electron", "desktop"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Sessions ativas",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "g4os_session_active_count{app=\"g4os\"}",
          "legendFormat": "sessions"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "MCP subprocessos",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "g4os_mcp_subprocess_count{app=\"g4os\"}",
          "legendFormat": "subprocessos"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "RSS Memory",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300000000 },
              { "color": "red", "value": 600000000 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "g4os_process_resident_memory_bytes{app=\"g4os\"}",
          "legendFormat": "RSS"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Turns iniciados (total)",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(g4os_turns_started_total{app=\"g4os\"})",
          "legendFormat": "turns"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Turn errors (total)",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(g4os_turn_errors_total{app=\"g4os\"})",
          "legendFormat": "errors"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Event loop lag p99",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(g4os_nodejs_eventloop_lag_seconds_bucket{app=\"g4os\"}[5m])) * 1000",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Turn duration (ms) — p50 / p95 / p99",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by(le) (rate(g4os_turn_duration_ms_bucket{app=\"g4os\"}[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by(le) (rate(g4os_turn_duration_ms_bucket{app=\"g4os\"}[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by(le) (rate(g4os_turn_duration_ms_bucket{app=\"g4os\"}[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Tokens consumidos / min",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by(direction) (rate(g4os_turn_tokens_total{app=\"g4os\"}[1m]) * 60)",
          "legendFormat": "{{direction}}"
        }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "IPC requests / s — por status",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by(status) (rate(g4os_ipc_request_total{app=\"g4os\"}[1m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "IPC latência p95 — por procedure (top 10)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.95, sum by(procedure, le) (rate(g4os_ipc_request_duration_seconds_bucket{app=\"g4os\"}[5m]))))",
          "legendFormat": "{{procedure}}"
        }
      ]
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "Heap used vs total",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      },
      "targets": [
        {
          "expr": "g4os_nodejs_heap_size_used_bytes{app=\"g4os\"}",
          "legendFormat": "heap used"
        },
        {
          "expr": "g4os_nodejs_heap_size_total_bytes{app=\"g4os\"}",
          "legendFormat": "heap total"
        }
      ]
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "MCP tool call duration p95 — por tool",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by(tool, le) (rate(g4os_mcp_tool_call_duration_seconds_bucket{app=\"g4os\"}[5m])))",
          "legendFormat": "{{tool}}"
        }
      ]
    }
  ]
}
