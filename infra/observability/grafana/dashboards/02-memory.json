{
  "uid": "g4os-memory",
  "title": "G4OS Memory",
  "description": "Heap, RSS, listeners e GC pressure do main process Electron",
  "tags": ["g4os", "memory", "leak"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(g4os_process_resident_memory_bytes, service)",
        "current": { "text": "g4os-desktop", "value": "g4os-desktop" },
        "multi": true,
        "includeAll": true
      },
      {
        "name": "env",
        "type": "custom",
        "query": "dev,staging,prod",
        "current": { "text": "dev", "value": "dev" },
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Heap used vs total",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "expr": "g4os_nodejs_heap_size_used_bytes{service=~\"$service\"}",
          "legendFormat": "heap used"
        },
        {
          "expr": "g4os_nodejs_heap_size_total_bytes{service=~\"$service\"}",
          "legendFormat": "heap total"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "RSS memory",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 600000000 },
              { "color": "red", "value": 1000000000 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "g4os_process_resident_memory_bytes{service=~\"$service\"}",
          "legendFormat": "RSS"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Heap growth rate (5m)",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 33000 },
              { "color": "red", "value": 87000 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "deriv(g4os_nodejs_heap_size_used_bytes{service=~\"$service\"}[5m])",
          "legendFormat": "heap growth"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Listener count by origin (top 10)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(10, g4os_event_listener_count{service=~\"$service\"})",
          "legendFormat": "{{origin}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "GC pause p95 / p99",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by(le) (rate(g4os_nodejs_gc_pause_seconds_bucket{service=~\"$service\"}[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by(le) (rate(g4os_nodejs_gc_pause_seconds_bucket{service=~\"$service\"}[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Heap fragmentation (used / total)",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 } },
      "targets": [
        {
          "expr": "g4os_nodejs_heap_size_used_bytes{service=~\"$service\"} / g4os_nodejs_heap_size_total_bytes{service=~\"$service\"}",
          "legendFormat": "used/total"
        }
      ]
    }
  ]
}
