{
  "uid": "g4os-ipc",
  "title": "G4OS IPC / tRPC",
  "description": "Volume + latência + erros do tRPC IPC entre renderer e main",
  "tags": ["g4os", "ipc", "trpc"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(g4os_ipc_request_total, service)",
        "current": { "text": "g4os-desktop", "value": "g4os-desktop" },
        "multi": true,
        "includeAll": true
      },
      {
        "name": "env",
        "type": "custom",
        "query": "dev,staging,prod",
        "current": { "text": "dev", "value": "dev" },
        "multi": true,
        "includeAll": true
      },
      {
        "name": "router",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(g4os_ipc_request_total{service=~\"$service\"}, router)",
        "current": { "text": "All", "value": "$__all" },
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Requests / s",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(rate(g4os_ipc_request_total{service=~\"$service\",router=~\"$router\"}[1m]))",
          "legendFormat": "rps"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error rate",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(rate(g4os_ipc_request_total{service=~\"$service\",status=\"error\",router=~\"$router\"}[5m])) / clamp_min(sum(rate(g4os_ipc_request_total{service=~\"$service\",router=~\"$router\"}[5m])), 1)",
          "legendFormat": "error %"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Latency p50",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by(le) (rate(g4os_ipc_request_duration_seconds_bucket{service=~\"$service\",router=~\"$router\"}[5m])))",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Latency p95",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by(le) (rate(g4os_ipc_request_duration_seconds_bucket{service=~\"$service\",router=~\"$router\"}[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Requests por status",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by(status) (rate(g4os_ipc_request_total{service=~\"$service\",router=~\"$router\"}[1m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Latência p50 / p95 / p99",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by(le) (rate(g4os_ipc_request_duration_seconds_bucket{service=~\"$service\",router=~\"$router\"}[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by(le) (rate(g4os_ipc_request_duration_seconds_bucket{service=~\"$service\",router=~\"$router\"}[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by(le) (rate(g4os_ipc_request_duration_seconds_bucket{service=~\"$service\",router=~\"$router\"}[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Top 10 procedures por p95",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.95, sum by(procedure, le) (rate(g4os_ipc_request_duration_seconds_bucket{service=~\"$service\",router=~\"$router\"}[5m]))))",
          "legendFormat": "{{procedure}}"
        }
      ]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Top 10 procedures por error rate",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [
        {
          "expr": "topk(10, sum by(procedure) (rate(g4os_ipc_request_total{service=~\"$service\",status=\"error\",router=~\"$router\"}[5m])) / clamp_min(sum by(procedure) (rate(g4os_ipc_request_total{service=~\"$service\",router=~\"$router\"}[5m])), 1))",
          "legendFormat": "{{procedure}}"
        }
      ]
    }
  ]
}
