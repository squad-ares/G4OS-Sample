{
  "uid": "g4os-vault",
  "title": "G4OS Credentials Vault",
  "description": "Métricas do CredentialVault: get/set rate, errors, mutex contention, expirations, refresh queue",
  "tags": ["g4os", "vault", "credentials", "security"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(g4os_vault_get_total, service)",
        "current": { "text": "g4os-desktop", "value": "g4os-desktop" },
        "multi": true,
        "includeAll": true
      },
      {
        "name": "env",
        "type": "custom",
        "query": "dev,staging,prod",
        "current": { "text": "dev", "value": "dev" },
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Vault gets / min",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(rate(g4os_vault_get_total{service=~\"$service\"}[1m]) * 60)",
          "legendFormat": "gets/min"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Vault sets / min",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(rate(g4os_vault_set_total{service=~\"$service\"}[1m]) * 60)",
          "legendFormat": "sets/min"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error rate",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(rate(g4os_vault_errors_total{service=~\"$service\"}[5m])) / clamp_min(sum(rate(g4os_vault_get_total{service=~\"$service\"}[5m])) + sum(rate(g4os_vault_set_total{service=~\"$service\"}[5m])), 1)",
          "legendFormat": "errors %"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Tokens expirando 24h",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "g4os_vault_tokens_expiring_24h{service=~\"$service\"}",
          "legendFormat": "expiring"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Vault operations rate",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(g4os_vault_get_total{service=~\"$service\"}[1m]))",
          "legendFormat": "get"
        },
        {
          "expr": "sum(rate(g4os_vault_set_total{service=~\"$service\"}[1m]))",
          "legendFormat": "set"
        },
        {
          "expr": "sum(rate(g4os_vault_delete_total{service=~\"$service\"}[1m]))",
          "legendFormat": "delete"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Vault error rate por kind",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by(kind) (rate(g4os_vault_errors_total{service=~\"$service\"}[5m]))",
          "legendFormat": "{{kind}}"
        }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Mutex wait time p95",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by(le) (rate(g4os_vault_mutex_wait_seconds_bucket{service=~\"$service\"}[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by(le) (rate(g4os_vault_mutex_wait_seconds_bucket{service=~\"$service\"}[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Refresh queue depth",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "g4os_vault_refresh_queue_depth{service=~\"$service\"}",
          "legendFormat": "queue depth"
        },
        {
          "expr": "sum(rate(g4os_vault_refresh_total{service=~\"$service\"}[1m]))",
          "legendFormat": "refresh rate"
        }
      ]
    }
  ]
}
