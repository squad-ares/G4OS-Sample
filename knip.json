{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/*.ts"],
      "ignoreDependencies": [
        "esbuild",
        "publint",
        "ts-prune",
        "@commitlint/types",
        "@arethetypeswrong/cli",
        "size-limit",
        "electron",
        "electron-vite"
      ]
    },
    "apps/desktop": {
      "entry": [
        "src/index.ts",
        "src/preload.ts",
        "src/main/index.ts",
        "src/main/agents-bootstrap.ts",
        "src/main/services/db-service.ts",
        "src/main/services/backup-scheduler.ts",
        "src/main/workers/session-worker.ts",
        "src/main/workers/cpu-pool/tasks.ts",
        "src/renderer/index.html",
        "src/renderer/**/*.tsx",
        "src/renderer/**/*.ts",
        "electron.vite.config.ts"
      ],
      "ignoreDependencies": ["pino-pretty", "pino-roll", "@supabase/supabase-js", "pino"]
    },
    "packages/features": {
      "entry": ["src/**/*.tsx", "src/**/*.ts"],
      "ignoreDependencies": [
        "@g4os/ipc",
        "@g4os/kernel",
        "@tanstack/react-router",
        "@trpc/client",
        "react-dom",
        "@types/react-dom"
      ]
    },
    "packages/ipc": {
      "ignoreDependencies": ["@trpc/client", "electron-trpc"]
    },
    "packages/kernel": {
      "ignoreDependencies": ["pino-pretty", "pino-roll"]
    },
    "packages/observability": {
      "ignoreDependencies": ["@opentelemetry/sdk-node", "@opentelemetry/exporter-trace-otlp-http"]
    },
    "packages/ui": {
      "entry": ["src/**/*.tsx", "src/**/*.ts"],
      "ignoreDependencies": ["@tanstack/react-query", "@trpc/react-query"]
    }
  },
  "ignoreExportsUsedInFile": true
}
