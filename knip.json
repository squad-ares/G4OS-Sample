{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/*.ts"],
      "ignoreDependencies": [
        "esbuild",
        "publint",
        "ts-prune",
        "@commitlint/types",
        "@arethetypeswrong/cli",
        "size-limit",
        "electron",
        "electron-vite"
      ],
      "ignoreBinaries": ["prebundle", "electron-builder"]
    },
    "apps/desktop": {
      "entry": [
        "src/index.ts",
        "src/preload.ts",
        "src/main/index.ts",
        "src/main/agents-bootstrap.ts",
        "src/main/services/db-service.ts",
        "src/main/services/backup-scheduler.ts",
        "src/main/services/transcription.ts",
        "src/main/services/update-service.ts",
        "src/main/__tests__/**/*.ts",
        "src/renderer/index.html",
        "src/renderer/**/*.tsx",
        "src/renderer/**/*.ts",
        "electron.vite.config.ts",
        "electron-builder.config.ts",
        "scripts/after-pack.ts",
        "scripts/sign-windows.ts",
        "scripts/notarize-macos.ts",
        "scripts/regenerate-metadata.ts",
        "scripts/bundle-runtimes/**/*.ts"
      ],
      "ignoreDependencies": [
        "pino-pretty",
        "pino-roll",
        "@supabase/supabase-js",
        "pino",
        "@anthropic-ai/sdk",
        "@pinojs/redact",
        "atomic-sleep",
        "date-fns",
        "on-exit-leak-free",
        "pino-abstract-transport",
        "pino-std-serializers",
        "process-warning",
        "quick-format-unescaped",
        "real-require",
        "safe-stable-stringify",
        "sonic-boom",
        "thread-stream"
      ],
      "ignoreBinaries": ["tar", "powershell", "xcrun", "signtool", "smctl", "AzureSignTool"]
    },
    "apps/desktop-e2e": {
      "entry": ["tests/**/*.ts"]
    },
    "packages/features": {
      "entry": ["src/**/*.tsx", "src/**/*.ts"],
      "ignoreDependencies": [
        "@g4os/ipc",
        "@tanstack/react-router",
        "@trpc/client",
        "react-markdown",
        "rehype-raw",
        "remark-gfm",
        "shiki"
      ]
    },
    "packages/ipc": {
      "ignoreDependencies": ["@trpc/client", "electron-trpc"]
    },
    "packages/kernel": {
      "ignoreDependencies": ["pino-pretty", "pino-roll"]
    },
    "packages/observability": {
      "ignoreDependencies": ["@opentelemetry/sdk-node", "@opentelemetry/exporter-trace-otlp-http"]
    },
    "packages/ui": {
      "entry": ["src/**/*.tsx", "src/**/*.ts"],
      "ignoreDependencies": ["@tanstack/react-query", "@trpc/react-query"]
    }
  },
  "ignoreExportsUsedInFile": true
}
