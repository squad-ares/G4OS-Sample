{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/*.ts"],
      "ignoreDependencies": [
        "esbuild",
        "publint",
        "ts-prune",
        "@commitlint/types",
        "@arethetypeswrong/cli",
        "size-limit"
      ]
    },
    "apps/desktop": {
      "entry": ["src/index.ts", "src/preload.ts"]
    },
    "packages/ipc": {
      "ignoreDependencies": ["@trpc/client", "electron-trpc"]
    },
    "packages/kernel": {
      "ignoreDependencies": ["pino-pretty"]
    },
    "packages/ui": {
      "ignoreDependencies": [
        "@tanstack/react-query",
        "@trpc/react-query",
        "react-dom",
        "@types/react-dom"
      ]
    }
  },
  "ignoreExportsUsedInFile": true
}
