{
  "name": "@g4os/monorepo",
  "version": "0.0.001-beta",
  "private": true,
  "description": "G4 OS - Multi-session AI agent management desktop app",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint && pnpm run check:i18n",
    "lint:fix": "turbo run lint -- --fix",
    "check:i18n": "tsx scripts/check-i18n-strings.ts",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch --parallel",
    "dev": "turbo run dev --parallel",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "lefthook install",
    "check:file-lines": "tsx scripts/check-file-lines.ts",
    "check:circular": "madge --circular --extensions ts,tsx packages apps",
    "check:cruiser": "depcruise --config .dependency-cruiser.cjs packages apps",
    "check:dead-code": "knip",
    "check:unused-deps": "knip --dependencies",
    "check:exports": "tsx scripts/check-exports.ts",
    "check:size": "tsx scripts/check-size.ts",
    "check:main-size": "tsx scripts/check-main-size.ts",
    "check:platform-leaks": "tsx scripts/check-platform-leaks.ts",
    "check:hover-pattern": "tsx scripts/check-hover-pattern.ts",
    "check:translation-key-cast": "tsx scripts/check-translation-key-cast.ts",
    "check:comment-rot": "tsx scripts/check-comment-rot.ts",
    "check:promise-race": "tsx scripts/check-promise-race-rollback.ts",
    "check:abort-signal": "tsx scripts/check-abort-signal.ts",
    "changeset": "changeset",
    "changeset:version": "changeset version && pnpm install --lockfile-only",
    "changeset:publish": "changeset publish",
    "changeset:status": "changeset status --since=origin/main",
    "adr:new": "tsx scripts/new-adr.ts",
    "db:migrate:status": "tsx scripts/db-migrate-status.mts",
    "migrate:v1": "tsx scripts/migrate-v1.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "madge>typescript": "6.0.3"
      },
      "ignoreMissing": [
        "electron",
        "mssql",
        "@types/mssql"
      ]
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@biomejs/biome": "2.4.12",
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.31.0",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@g4os/data": "workspace:*",
    "@g4os/migration": "workspace:*",
    "@g4os/platform": "workspace:*",
    "@tailwindcss/vite": "4.2.4",
    "@types/node": "25.6.0",
    "dependency-cruiser": "17.3.10",
    "electron": "^41.2.2",
    "electron-vite": "^5.0.0",
    "esbuild": "0.28.0",
    "glob": "13.0.6",
    "knip": "6.6.0",
    "lefthook": "2.1.6",
    "madge": "8.0.0",
    "publint": "0.3.18",
    "size-limit": "12.1.0",
    "tailwindcss": "4.2.4",
    "ts-prune": "0.10.3",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "turbo": "2.9.6",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
