# * Determinismo absoluto
save-exact=true
engine-strict=true
strict-peer-dependencies=true

# * Node 24 LTS gerenciado pelo pnpm (ADR-0040a — node:sqlite estável).
# * Contribuidores sem nvm/fnm ganham Node 24 automaticamente no primeiro `pnpm install`.
use-node-version=24.10.0

# * Segurança
prefer-frozen-lockfile=true
fund=false
audit=false

# * Hoisting controlado (evita módulos fantasma)
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=*biome*
public-hoist-pattern[]=@types/*
shamefully-hoist=false

# * Peer deps rígido
auto-install-peers=false
resolve-peers-from-workspace-root=true

# * Registry
registry=https://registry.npmjs.org/