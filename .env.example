# ============================================================================
# G4 OS v2 — Runtime environment contract
# ----------------------------------------------------------------------------
# Copy this file to `.env` (preferred) or `.env.local` in the repo root.
# Neither is tracked by git. Variables here are consumed by the Electron main
# process and by build tooling (Vite composition root).
# ============================================================================

# ------------------------------------------------
# Auth — Supabase (required for OTP login)
# ------------------------------------------------
# Read by `validateSupabaseEnv` / `resolveSupabaseEnv` in @g4os/auth.
# Without these, the managed login flow fails at preflight.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional legacy alias; only one of ANON_KEY or PUBLISHABLE_KEY is required.
# SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# ------------------------------------------------
# App runtime (optional)
# ------------------------------------------------
# 'development' | 'production'. Controls dev-mode branches in platform-info
# and the pino logger (pretty-print when 'development').
# NODE_ENV=development

# pino log level: 'fatal' | 'error' | 'warn' | 'info' | 'debug' | 'trace'.
# Default: 'info'.
# LOG_LEVEL=info

# Distribution flavor — 'public' (default) or 'internal'.
# Changes app paths (~/.g4os vs ~/.g4os-internal) and some UI branding.
# G4OS_DISTRIBUTION_FLAVOR=public

# ------------------------------------------------
# Observability — opt-in (ADRs 0060-0065)
# Without these, the observability pipeline initializes in NOOP mode.
# ------------------------------------------------
# OpenTelemetry OTLP collector endpoint (HTTP). Enables tracing when set.
# G4OS_OTEL_ENDPOINT=http://localhost:4318/v1/traces

# OTel sample ratio between 0 and 1. Default: 0.1 (10% sampling).
# G4OS_OTEL_SAMPLE_RATIO=0.1

# Sentry DSN. Enables crash reporting when set.
# G4OS_SENTRY_DSN=https://<key>@o0.ingest.sentry.io/0

# Sentry environment label. Defaults to NODE_ENV-derived value.
# G4OS_SENTRY_ENVIRONMENT=development

# Sentry release tag. Defaults to app version.
# G4OS_SENTRY_RELEASE=0.9.992

# Memory monitor sample interval in ms. Default: 30000.
# G4OS_MEMORY_INTERVAL_MS=30000

# ------------------------------------------------
# Codex agent — binary resolution (ADR-0072)
# ------------------------------------------------
# Dev override: used first when set AND the file exists. Meant for local
# Codex dev builds; never ship a value here.
# CODEX_DEV_PATH=/abs/path/to/codex-dev

# Prod override: used when no dev path and the bundled runtime is missing.
# CODEX_PATH=/abs/path/to/codex

# ============================================================================
# Env vars set by tooling (do NOT set manually):
#   - ELECTRON_RENDERER_URL : injected by electron-vite in `pnpm dev`
#   - npm_package_version   : injected by npm/pnpm at runtime
#   - HOME / USERPROFILE    : provided by the OS
# ============================================================================
