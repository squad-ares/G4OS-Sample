# ============================================================================
# G4 OS v2 — Runtime environment contract
# ----------------------------------------------------------------------------
# Copy this file to `.env` (preferred) or `.env.local` in the repo root.
# Neither is tracked by git. Variables here are consumed by the Electron main
# process and by build tooling (Vite composition root).
# ============================================================================

# ------------------------------------------------
# Auth — Supabase (required for OTP login)
# ------------------------------------------------
# Read by `validateSupabaseEnv` / `resolveSupabaseEnv` in @g4os/auth.
# Without these, the managed login flow fails at preflight.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional legacy alias; only one of ANON_KEY or PUBLISHABLE_KEY is required.
# SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# ------------------------------------------------
# App runtime (optional)
# ------------------------------------------------
# 'development' | 'production'. Controls dev-mode branches in platform-info
# and the pino logger (pretty-print when 'development').
# NODE_ENV=development

# pino log level: 'fatal' | 'error' | 'warn' | 'info' | 'debug' | 'trace'.
# Default: 'info'.
# LOG_LEVEL=info

# Distribution flavor — 'public' (default) or 'internal'.
# Changes app paths (~/.g4os vs ~/.g4os-internal) and some UI branding.
# G4OS_DISTRIBUTION_FLAVOR=public

# Managed API base URL (entitlement + refresh endpoints).
# Required in production builds served by the DreamSquad backend.
# G4OS_MANAGED_API_BASE=https://api.g4os.app

# Viewer URL for the news/hub feed. Defaults to the production viewer.
# Override in staging/dev to point at a local viewer instance.
# G4OS_VIEWER_URL=https://viewer.g4os.app

# Skip Supabase env validation in CI builds or local packaging without credentials.
# The app boots and reports auth failures gracefully when set to '1'.
# G4OS_SKIP_SUPABASE_VALIDATION=1

# ------------------------------------------------
# Observability — opt-in (ADRs 0060-0065)
# Without these, the observability pipeline initializes in NOOP mode.
# ------------------------------------------------
# OpenTelemetry OTLP collector endpoint (HTTP). Enables tracing when set.
# G4OS_OTEL_ENDPOINT=http://localhost:4318/v1/traces

# OTel sample ratio between 0 and 1. Default: 0.1 (10% sampling).
# G4OS_OTEL_SAMPLE_RATIO=0.1

# Sentry DSN. Enables crash reporting when set.
# G4OS_SENTRY_DSN=https://<key>@o0.ingest.sentry.io/0

# Sentry environment label. Defaults to NODE_ENV-derived value.
# G4OS_SENTRY_ENVIRONMENT=development

# Sentry release tag. Defaults to app version.
# G4OS_SENTRY_RELEASE=0.9.992

# Memory monitor sample interval in ms. Default: 30000.
# G4OS_MEMORY_INTERVAL_MS=30000

# ------------------------------------------------
# Codex agent — binary resolution (ADR-0072)
# ------------------------------------------------
# Dev override: used first when set AND the file exists. Meant for local
# Codex dev builds; never ship a value here.
# CODEX_DEV_PATH=/abs/path/to/codex-dev

# Prod override: used when no dev path and the bundled runtime is missing.
# CODEX_PATH=/abs/path/to/codex

# ------------------------------------------------
# Local observability stack (infra/observability/)
# Only needed when rodando a stack LGTM local (make obs-up).
# ------------------------------------------------
# Senha do painel Grafana local. Padrão: 'admin' (só dev/local).
# GRAFANA_ADMIN_PASSWORD=admin

# ------------------------------------------------
# E2E / testing (opt-in)
# ------------------------------------------------
# Quando '1', o main process bypassa Supabase auth (`mockAuthMode`) e
# substitui o registro real de agents por um `createStubAgentFactory()`
# que emite text_delta fake sem rede. Lido por
# `apps/desktop/src/main/services/auth-runtime.ts` e setado pelo helper
# `apps/desktop-e2e/tests/helpers/launch-app.ts` quando `auth: 'mock'`.
# Nunca setar manualmente em dev — quebra o login real.
# G4OS_E2E=1

# Memlab gate noturno em `apps/desktop-e2e/tests/memory-cycle.e2e.ts`.
# Só executa o ciclo + heap diff quando '1'. CI noturno seta; dev local não.
# G4OS_E2E_MEMLAB=1

# ============================================================================
# Release tooling — build / packaging / signing
# ----------------------------------------------------------------------------
# Lidos por `apps/desktop/electron-builder.config.ts` e por scripts em
# `apps/desktop/scripts/`. Em dev local nenhum precisa estar setado; defaults
# cobrem `pnpm build`. Em CI release são injetados via secrets.
# ============================================================================

# ------------------------------------------------
# electron-builder identity / publish
# ------------------------------------------------
# Override do bundle identifier. Default: `com.g4educacao.g4os`.
# G4OS_APP_ID=com.g4educacao.g4os

# Override do nome do produto exibido no installer. Default: `G4 OS`.
# G4OS_APP_NAME=G4 OS

# Modo de assinatura macOS: 'adhoc' | 'signed' | 'skip'. Default: 'adhoc'.
# G4OS_MAC_SIGN_MODE=adhoc

# Provider de assinatura Windows: 'none' | 'azure-trusted-signing' | 'sectigo'.
# Default: 'none'.
# WIN_SIGN_PROVIDER=none

# Caminho ao .pfx local quando WIN_SIGN_PROVIDER=sectigo (legacy fallback).
# WIN_CSC_LINK=/abs/path/to/cert.pfx

# Sectigo (Code Signing Manager) API key — usado quando provider=sectigo
# para assinatura via cloud HSM.
# SM_API_KEY=

# Azure Trusted Signing tenant id — usado quando provider=azure-trusted-signing.
# AZURE_TENANT_ID=

# Modo de publish do electron-builder: 'r2' | 'github' | 'none'.
# Default: 'none' (build local sem upload).
# G4OS_PUBLISH_MODE=none

# Quando publish=r2, endpoint S3-compatível do Cloudflare R2 (obrigatório).
# R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com

# Bucket destino. Default: 'g4os-releases'.
# R2_BUCKET=g4os-releases

# ------------------------------------------------
# macOS notarization retry tuning
# ------------------------------------------------
# Tentativas máximas de submeter pra notarytool antes de falhar. Default: 3.
# MAC_NOTARIZE_ATTEMPTS=3

# Delay (segundos) entre tentativas de notarytool. Default: 30.
# MAC_NOTARIZE_RETRY_DELAY_SEC=30

# ------------------------------------------------
# Bundle / runtime packaging (`scripts/bundle-runtimes/`, `scripts/after-pack.ts`)
# ------------------------------------------------
# Flavor usado por `after-pack.ts` para gravar identidade no
# `install-meta.json` packaged. Espelha `G4OS_DISTRIBUTION_FLAVOR` em build.
# Default: 'public'.
# G4OS_APP_FLAVOR=public

# Canal de release que vai pro `install-meta.json`: 'stable' | 'beta' | 'canary'.
# Default: 'stable'.
# G4OS_RELEASE_CHANNEL=stable

# Profile de runtimes empacotados ('full' | 'light' — light empacota só
# node + pnpm, full inclui git, uv, python). Default: 'full'.
# G4OS_BUNDLE_PROFILE=full

# Override do platform alvo do bundle ('darwin' | 'win32' | 'linux').
# Default: detectado de `process.platform`.
# G4OS_BUNDLE_PLATFORM=darwin

# Override do arch alvo do bundle ('arm64' | 'x64'). Default: `process.arch`.
# G4OS_BUNDLE_ARCH=arm64

# Diretório de saída dos artefatos bundlados. Default: `dist/runtime/`.
# G4OS_BUNDLE_OUTPUT=dist/runtime

# Modo de checksum no manifesto: 'strict' (verifica todos antes de empacotar)
# ou 'lenient' (loga warn e prossegue). Default: 'strict'.
# G4OS_BUNDLE_CHECKSUM_MODE=strict

# Escape hatch — quando '1', `after-pack.ts` pula a validação de runtimes
# bundlados. Use só para reproduzir builds problemáticos localmente.
# G4OS_SKIP_RUNTIME_VALIDATION=1

# ============================================================================
# Env vars set by tooling (do NOT set manually):
#   - ELECTRON_RENDERER_URL : injected by electron-vite in `pnpm dev`
#   - npm_package_version   : injected by npm/pnpm at runtime
#   - HOME / USERPROFILE    : provided by the OS
#   - __G4OS_SUPABASE_URL__, __G4OS_SUPABASE_ANON_KEY__,
#     __G4OS_SENTRY_DSN__, __G4OS_SENTRY_ENVIRONMENT__,
#     __G4OS_SENTRY_RELEASE__ : build-time defines via electron-vite
#                                (derivados das vars runtime acima)
# ============================================================================
