{
  "name": "@g4os/desktop",
  "version": "0.0.13-canary",
  "description": "G4 OS - Aplicativo desktop (Electron)",
  "private": true,
  "homepage": "https://g4educacao.com",
  "author": {
    "name": "G4 Educação",
    "email": "engenharia@g4educacao.com"
  },
  "main": "./out/main/index.cjs",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "check": "biome check --write src",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "dev": "cross-env ELECTRON_RUN_AS_NODE= electron-vite dev",
    "build": "electron-vite build",
    "prebundle": "tsx scripts/bundle-runtimes/index.ts",
    "dist": "pnpm build && electron-builder --config electron-builder.config.ts",
    "dist:mac": "pnpm build && electron-builder --mac --config electron-builder.config.ts",
    "dist:win": "pnpm build && electron-builder --win --config electron-builder.config.ts",
    "dist:linux": "pnpm build && electron-builder --linux --config electron-builder.config.ts",
    "dist:dir": "pnpm build && electron-builder --dir --config electron-builder.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.91.0",
    "@g4os/agents": "workspace:^",
    "@g4os/auth": "workspace:^",
    "@g4os/release-channels": "workspace:^",
    "@g4os/credentials": "workspace:^",
    "@g4os/data": "workspace:^",
    "@g4os/features": "workspace:^",
    "@g4os/ipc": "workspace:^",
    "@g4os/kernel": "workspace:^",
    "@g4os/migration": "workspace:^",
    "@g4os/observability": "workspace:^",
    "@g4os/permissions": "workspace:^",
    "@g4os/platform": "workspace:^",
    "@g4os/session-runtime": "workspace:^",
    "@g4os/sources": "workspace:^",
    "@g4os/ui": "workspace:^",
    "@pinojs/redact": "0.4.0",
    "@supabase/auth-js": "2.104.1",
    "@supabase/functions-js": "2.104.1",
    "@supabase/node-fetch": "2.6.13",
    "@supabase/postgrest-js": "2.104.1",
    "@supabase/realtime-js": "2.104.1",
    "@supabase/storage-js": "2.104.1",
    "@supabase/supabase-js": "2.52.1",
    "@tanstack/react-query": "5.99.2",
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-virtual": "3.13.24",
    "@trpc/client": "catalog:",
    "@trpc/react-query": "catalog:",
    "archiver": "catalog:",
    "atomic-sleep": "1.0.0",
    "date-fns": "4.1.0",
    "drizzle-orm": "catalog:",
    "zod": "catalog:",
    "electron-trpc": "catalog:",
    "electron-updater": "6.8.3",
    "isows": "1.0.7",
    "neverthrow": "catalog:",
    "on-exit-leak-free": "2.1.2",
    "pino": "catalog:",
    "pino-abstract-transport": "3.0.0",
    "pino-pretty": "catalog:",
    "pino-roll": "catalog:",
    "pino-std-serializers": "7.1.0",
    "piscina": "5.1.4",
    "lucide-react": "catalog:",
    "process-warning": "5.0.0",
    "quick-format-unescaped": "4.0.4",
    "react": "catalog:",
    "react-dom": "catalog:",
    "real-require": "1.0.0",
    "rxjs": "catalog:",
    "safe-stable-stringify": "2.5.0",
    "sonic-boom": "5.0.0",
    "superjson": "catalog:",
