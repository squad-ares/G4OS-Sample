{
  "name": "@g4os/desktop",
  "version": "0.0.0",
  "description": "G4 OS - Aplicativo desktop (Electron)",
  "private": true,
  "main": "./out/main/index.cjs",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "check": "biome check --write src",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "dev": "cross-env ELECTRON_RUN_AS_NODE= electron-vite dev",
    "build": "electron-vite build"
  },
  "dependencies": {
    "@g4os/agents": "workspace:^",
    "@g4os/auth": "workspace:^",
    "@g4os/data": "workspace:^",
    "@g4os/features": "workspace:^",
    "@g4os/ipc": "workspace:^",
    "@g4os/credentials": "workspace:^",
    "@g4os/kernel": "workspace:^",
    "@g4os/observability": "workspace:^",
    "@g4os/platform": "workspace:^",
    "@g4os/ui": "workspace:^",
    "@tanstack/react-query": "5.99.2",
    "@tanstack/react-router": "1.168.23",
    "@trpc/client": "11.16.0",
    "@trpc/react-query": "11.16.0",
    "@supabase/supabase-js": "2.52.1",
    "electron-trpc": "0.7.1",
    "neverthrow": "8.2.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "pino-roll": "4.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "superjson": "2.2.6"
  },
  "devDependencies": {
    "@tanstack/router-vite-plugin": "1.166.37",
    "@types/node": "25.6.0",
    "cross-env": "7.0.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.2.1",
    "electron-vite": "^5.0.0",
    "vite": "^8.0.9"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
