{
  "name": "@g4os/desktop",
  "version": "0.0.2",
  "description": "G4 OS - Aplicativo desktop (Electron)",
  "private": true,
  "homepage": "https://g4educacao.com",
  "author": {
    "name": "G4 Educação",
    "email": "engenharia@g4educacao.com"
  },
  "main": "./out/main/index.cjs",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "check": "biome check --write src",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "dev": "cross-env ELECTRON_RUN_AS_NODE= electron-vite dev",
    "build": "electron-vite build",
    "prebundle": "tsx scripts/bundle-runtimes/index.ts",
    "dist": "pnpm build && electron-builder --config electron-builder.config.ts",
    "dist:mac": "pnpm build && electron-builder --mac --config electron-builder.config.ts",
    "dist:win": "pnpm build && electron-builder --win --config electron-builder.config.ts",
    "dist:linux": "pnpm build && electron-builder --linux --config electron-builder.config.ts",
    "dist:dir": "pnpm build && electron-builder --dir --config electron-builder.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.91.0",
    "@g4os/agents": "workspace:^",
    "@g4os/auth": "workspace:^",
    "@g4os/credentials": "workspace:^",
    "@g4os/data": "workspace:^",
    "@g4os/features": "workspace:^",
    "@g4os/ipc": "workspace:^",
    "@g4os/kernel": "workspace:^",
    "@g4os/observability": "workspace:^",
    "@g4os/permissions": "workspace:^",
    "@g4os/platform": "workspace:^",
    "@g4os/session-runtime": "workspace:^",
    "@g4os/sources": "workspace:^",
    "@g4os/ui": "workspace:^",
    "@pinojs/redact": "0.4.0",
    "@supabase/supabase-js": "2.52.1",
    "@tanstack/react-query": "5.99.2",
    "@tanstack/react-router": "1.168.23",
    "@trpc/client": "11.16.0",
    "@trpc/react-query": "11.16.0",
    "archiver": "7.0.1",
    "atomic-sleep": "1.0.0",
    "date-fns": "4.1.0",
    "drizzle-orm": "1.0.0-beta.17-8a36f93",
    "electron-trpc": "0.7.1",
    "electron-updater": "6.8.3",
    "neverthrow": "8.2.0",
    "on-exit-leak-free": "2.1.2",
    "pino": "10.3.1",
    "pino-abstract-transport": "3.0.0",
    "pino-pretty": "13.1.3",
    "pino-roll": "4.0.0",
    "pino-std-serializers": "7.1.0",
    "process-warning": "5.0.0",
    "quick-format-unescaped": "4.0.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "real-require": "1.0.0",
    "rxjs": "7.8.2",
    "safe-stable-stringify": "2.5.0",
    "sonic-boom": "5.0.0",
    "superjson": "2.2.6",
    "thread-stream": "4.0.0",
    "yauzl": "3.3.0"
  },
  "devDependencies": {
    "@tanstack/router-vite-plugin": "1.166.37",
    "@types/archiver": "7.0.0",
    "@types/node": "25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/yauzl": "2.10.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "7.0.3",
    "electron": "^41.3.0",
    "electron-builder": "26.8.1",
    "electron-vite": "^5.0.0",
    "execa": "9.6.1",
    "tsx": "4.21.0",
    "vite": "^8.0.9"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
