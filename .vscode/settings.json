{
  "editor.defaultFormatter": "biomejs.biome",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.biome": "explicit"
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "cSpell.words": [
    "adrs",
    "attw",
    "backpressure",
    "bgcolor",
    "codegen",
    "commitlint",
    "depcruise",
    "educacao",
    "github",
    "Gmail",
    "impls",
    "lefthook",
    "madge",
    "neverthrow",
    "nvmrc",
    "Turborepo"
  ]
}
