{
  "name": "@g4os/credentials",
  "version": "0.0.0",
  "description": "Vault",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./backends": {
      "types": "./src/backends/index.ts",
      "import": "./src/backends/index.ts"
    },
    "./migration": {
      "types": "./src/migration/index.ts",
      "import": "./src/migration/index.ts"
    },
    "./rotation": {
      "types": "./src/rotation/index.ts",
      "import": "./src/rotation/index.ts"
    }
  },
  "dependencies": {
    "@g4os/kernel": "workspace:*",
    "@g4os/platform": "workspace:*",
    "async-mutex": "0.5.0",
    "neverthrow": "8.2.0"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "vitest": "4.1.4"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "check": "biome check --write src",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
