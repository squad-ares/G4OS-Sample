{
  "name": "@g4os/kernel",
  "version": "0.0.0",
  "description": "Types, errors. CR-18 F-K3: padrão workspace-source-direct — exports apontam para `./src/*.ts`. Build via tsup gera `dist/` mas é desperdício de CI; consumers internos resolvem via tsx/vite-node em dev e via bundler em prod (apps/desktop empacota tudo). Não publicado externamente (`private:true`); attw + tipos vivos com `noUncheckedIndexedAccess` são prioridade vs publish artifacts.",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "import": "./src/types/index.ts"
    },
    "./schemas": {
      "types": "./src/schemas/index.ts",
      "import": "./src/schemas/index.ts"
    },
    "./errors": {
      "types": "./src/errors/index.ts",
      "import": "./src/errors/index.ts"
    },
    "./logger": {
      "types": "./src/logger/index.ts",
      "import": "./src/logger/index.ts"
    },
    "./log-stream": {
      "types": "./src/logger/log-stream.ts",
      "import": "./src/logger/log-stream.ts"
    },
    "./logger-transport": {
      "types": "./src/logger/transport.ts",
      "import": "./src/logger/transport.ts"
    },
    "./validation": {
      "types": "./src/validation/index.ts",
      "import": "./src/validation/index.ts"
    },
    "./disposable": {
      "types": "./src/disposable/index.ts",
      "import": "./src/disposable/index.ts"
    },
    "./serialization": {
      "types": "./src/serialization/index.ts",
      "import": "./src/serialization/index.ts"
    },
    "./fs": {
      "types": "./src/fs/index.ts",
      "import": "./src/fs/index.ts"
    }
  },
  "dependencies": {
    "neverthrow": "catalog:",
    "pino": "catalog:",
    "pino-pretty": "catalog:",
    "pino-roll": "catalog:",
    "zod": "catalog:"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit --project tsconfig.json && tsc --noEmit --project tsconfig.test.json",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "check": "biome check --write src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@types/node": "catalog:"
  }
}
