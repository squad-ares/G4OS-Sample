{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // noEmit: tsup é o único produtor de artefatos de build.
    // outDir/rootDir omitidos propositalmente — não há emissão via tsc.
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["src/**/*"],
  "exclude": ["src/**/*.test.ts", "src/__tests__/**"]
}
