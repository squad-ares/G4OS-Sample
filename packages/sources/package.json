{
  "name": "@g4os/sources",
  "version": "0.0.0",
  "description": "Source plugin contract, MCP stdio/http, managed connectors, OAuth kit, lifecycle manager",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./interface": {
      "types": "./src/interface/index.ts",
      "import": "./src/interface/index.ts"
    },
    "./mcp-stdio": {
      "types": "./src/mcp-stdio/index.ts",
      "import": "./src/mcp-stdio/index.ts"
    },
    "./mcp-http": {
      "types": "./src/mcp-http/index.ts",
      "import": "./src/mcp-http/index.ts"
    },
    "./managed": {
      "types": "./src/managed/index.ts",
      "import": "./src/managed/index.ts"
    },
    "./oauth": {
      "types": "./src/oauth/index.ts",
      "import": "./src/oauth/index.ts"
    },
    "./lifecycle": {
      "types": "./src/lifecycle/index.ts",
      "import": "./src/lifecycle/index.ts"
    },
    "./planner": {
      "types": "./src/planner/index.ts",
      "import": "./src/planner/index.ts"
    },
    "./catalog": {
      "types": "./src/catalog/index.ts",
      "import": "./src/catalog/index.ts"
    },
    "./store": {
      "types": "./src/store/index.ts",
      "import": "./src/store/index.ts"
    },
    "./broker": {
      "types": "./src/broker/index.ts",
      "import": "./src/broker/index.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "check": "biome check --write src",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@g4os/agents": "workspace:*",
    "@g4os/kernel": "workspace:*",
    "@g4os/platform": "workspace:*",
    "neverthrow": "catalog:",
    "rxjs": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "vitest": "catalog:"
  }
}
