{
  "name": "@g4os/data",
  "version": "0.0.0",
  "description": "Data layer: SQLite persistence, schemas, repositories",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./sqlite": {
      "types": "./src/sqlite/index.ts",
      "import": "./src/sqlite/index.ts"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "import": "./src/schema/index.ts"
    },
    "./drizzle": {
      "types": "./src/drizzle.ts",
      "import": "./src/drizzle.ts"
    },
    "./migrations": {
      "types": "./src/migrations/index.ts",
      "import": "./src/migrations/index.ts"
    },
    "./events": {
      "types": "./src/events/index.ts",
      "import": "./src/events/index.ts"
    },
    "./attachments": {
      "types": "./src/attachments/index.ts",
      "import": "./src/attachments/index.ts"
    },
    "./backup": {
      "types": "./src/backup/index.ts",
      "import": "./src/backup/index.ts"
    },
    "./sessions": {
      "types": "./src/sessions/index.ts",
      "import": "./src/sessions/index.ts"
    },
    "./labels": {
      "types": "./src/labels/index.ts",
      "import": "./src/labels/index.ts"
    },
    "./projects": {
      "types": "./src/projects/index.ts",
      "import": "./src/projects/index.ts"
    },
    "./queries": {
      "types": "./src/queries/index.ts",
      "import": "./src/queries/index.ts"
    },
    "./workspaces": {
      "types": "./src/workspaces/index.ts",
      "import": "./src/workspaces/index.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "check": "biome check --write src",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@g4os/kernel": "workspace:^",
    "@g4os/platform": "workspace:^",
    "archiver": "catalog:",
    "async-mutex": "0.5.0",
    "drizzle-orm": "catalog:",
    "yauzl": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/archiver": "catalog:",
    "@types/node": "catalog:",
    "@types/yauzl": "catalog:",
    "drizzle-kit": "1.0.0-beta.17-8a36f93"
  }
}
