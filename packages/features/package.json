{
  "name": "@g4os/features",
  "version": "0.0.0",
  "description": "User-facing features",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./auth": {
      "types": "./src/auth/index.ts",
      "import": "./src/auth/index.ts"
    },
    "./chat": {
      "types": "./src/chat/index.ts",
      "import": "./src/chat/index.ts"
    },
    "./shell": {
      "types": "./src/shell/index.ts",
      "import": "./src/shell/index.ts"
    },
    "./onboarding": {
      "types": "./src/onboarding/index.ts",
      "import": "./src/onboarding/index.ts"
    },
    "./workspaces": {
      "types": "./src/workspaces/index.ts",
      "import": "./src/workspaces/index.ts"
    },
    "./sessions": {
      "types": "./src/sessions/index.ts",
      "import": "./src/sessions/index.ts"
    },
    "./projects": {
      "types": "./src/projects/index.ts",
      "import": "./src/projects/index.ts"
    },
    "./settings": {
      "types": "./src/settings/index.ts",
      "import": "./src/settings/index.ts"
    },
    "./news": {
      "types": "./src/news/index.ts",
      "import": "./src/news/index.ts"
    },
    "./sources": {
      "types": "./src/sources/index.ts",
      "import": "./src/sources/index.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "check": "biome check --write src",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@g4os/ipc": "workspace:^",
    "@g4os/kernel": "workspace:^",
    "@g4os/translate": "workspace:^",
    "@g4os/ui": "workspace:^",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-virtual": "3.13.24",
    "@trpc/client": "catalog:",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-hook-form": "^7.56.0",
    "react-markdown": "catalog:",
    "rehype-raw": "catalog:",
    "remark-gfm": "catalog:",
    "shiki": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:"
  }
}
