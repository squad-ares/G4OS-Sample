{
  "name": "@g4os/features",
  "version": "0.0.0",
  "description": "User-facing features",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./auth": {
      "types": "./src/auth/index.ts",
      "import": "./src/auth/index.ts"
    },
    "./shell": {
      "types": "./src/shell/index.ts",
      "import": "./src/shell/index.ts"
    },
    "./onboarding": {
      "types": "./src/onboarding/index.ts",
      "import": "./src/onboarding/index.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "check": "biome check --write src",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@g4os/ipc": "workspace:^",
    "@g4os/kernel": "workspace:^",
    "@g4os/translate": "workspace:^",
    "@g4os/ui": "workspace:^",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-router": "1.168.23",
    "lucide-react": "^0.511.0",
    "@trpc/client": "11.16.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.56.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}
