{
  "name": "@g4os/agents",
  "version": "0.0.0",
  "description": "IAgent interface, registry, and plugin contract (implementations ship as separate packages)",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./interface": {
      "types": "./src/interface/index.ts",
      "import": "./src/interface/index.ts"
    },
    "./claude": {
      "types": "./src/claude/index.ts",
      "import": "./src/claude/index.ts"
    },
    "./codex": {
      "types": "./src/codex/index.ts",
      "import": "./src/codex/index.ts"
    },
    "./shared": {
      "types": "./src/shared/index.ts",
      "import": "./src/shared/index.ts"
    },
    "./streaming": {
      "types": "./src/streaming/index.ts",
      "import": "./src/streaming/index.ts"
    },
    "./permissions": {
      "types": "./src/permissions/index.ts",
      "import": "./src/permissions/index.ts"
    },
    "./openai": {
      "types": "./src/openai/index.ts",
      "import": "./src/openai/index.ts"
    },
    "./google": {
      "types": "./src/google/index.ts",
      "import": "./src/google/index.ts"
    },
    "./tools": {
      "types": "./src/tools/index.ts",
      "import": "./src/tools/index.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "check": "biome check --write src",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@g4os/kernel": "workspace:*",
    "@g4os/platform": "workspace:*",
    "neverthrow": "catalog:",
    "rxjs": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "vitest": "catalog:"
  }
}
