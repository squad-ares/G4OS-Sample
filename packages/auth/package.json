{
  "name": "@g4os/auth",
  "version": "0.0.0",
  "description": "Auth: Supabase OTP, managed login state machine, entitlement service, session refresher",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./src/types.ts"
    },
    "./otp": {
      "types": "./src/otp/index.ts",
      "import": "./src/otp/index.ts"
    },
    "./managed-login": {
      "types": "./src/managed-login/index.ts",
      "import": "./src/managed-login/index.ts"
    },
    "./entitlement": {
      "types": "./src/entitlement/index.ts",
      "import": "./src/entitlement/index.ts"
    },
    "./refresh": {
      "types": "./src/refresh/index.ts",
      "import": "./src/refresh/index.ts"
    },
    "./supabase": {
      "types": "./src/supabase/index.ts",
      "import": "./src/supabase/index.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "check": "biome check --write src",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@g4os/kernel": "workspace:*",
    "neverthrow": "catalog:",
    "rxjs": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "vitest": "catalog:"
  }
}
